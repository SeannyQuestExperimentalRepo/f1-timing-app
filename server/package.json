{
  "name": "@f1-timing/server",
  "version": "1.0.0",
  "description": "Fastify backend server for F1 timing app",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fastify": "^4.26.2",
    "@fastify/websocket": "^10.0.1",
    "@fastify/cors": "^9.0.1",
    "better-sqlite3": "^9.4.3",
    "zod": "^3.22.4",
    "@f1-timing/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.19",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "@vitest/coverage-v8": "^1.3.1"
  }
}